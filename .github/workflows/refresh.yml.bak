name: Daily data refresh

on:
  schedule:
    - cron: "0 6 * * *"   # 06:00 UTC daily
  workflow_dispatch:        # allows manual "Run workflow" button

permissions:
  contents: write

jobs:
  refresh:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Update deal statuses and fees
        run: python scripts/update_data.py

      - name: Commit and push if changed
        run: |
          git config user.name "transferintel-bot"
          git config user.email "actions@github.com"
          if ! git diff --quiet data.js; then
            git add data.js
            git commit -m "Data refresh $(date -u +%F)"
            git push
          else
            echo "No changes today."
          fi
